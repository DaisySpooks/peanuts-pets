# Copy to .env and fill in real values. Never commit .env.
#
# Discord Developer Portal (discord.com/developers/applications):
#   - Create/select an application, copy its Client ID and Client Secret.
#   - Under OAuth2 > Redirects, add a redirect URL that matches
#     DISCORD_REDIRECT_URI below EXACTLY (including path and protocol).
#   - Under Bot, create a bot user and copy its token (DISCORD_BOT_TOKEN).
#     No privileged gateway intents are needed — this app only calls the
#     REST "get guild member" endpoint, not the gateway.
#   - Invite the bot to your TEST Discord server with a link like:
#     https://discord.com/api/oauth2/authorize?client_id=YOUR_CLIENT_ID&scope=bot&permissions=0
#   - In the test server: enable Developer Mode in Discord, then right-click
#     the server / roles to copy DISCORD_GUILD_ID and the role IDs below.

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8787/auth/discord/callback
SESSION_SECRET=

# Bot used server-side only to look up guild membership + roles. Never sent
# to the frontend.
DISCORD_BOT_TOKEN=

# The Discord server (guild) users must belong to. Point this at your TEST
# server first; switching to the real server later is just an env change.
DISCORD_GUILD_ID=

# Role that grants access on its own.
DISCORD_PP_HOLDER_ROLE_ID=

# Optional bypass roles. Leave unset to disable that bypass entirely.
DISCORD_ADMIN_ROLE_ID=
DISCORD_TEAM_ROLE_ID=

# Supabase (supabase.com) — server-side pet persistence only.
#   - Create a project, then in the SQL Editor run:
#       create table public.pets (
#         id uuid primary key default gen_random_uuid(),
#         discord_user_id text not null unique,
#         pet_type text not null check (pet_type in ('axolotl', 'betta', 'turtle')),
#         pet_name text not null,
#         created_at timestamptz not null default now()
#       );
#       alter table public.pets enable row level security;
#     (RLS is enabled with no policies — only the service-role key below,
#     which bypasses RLS, can read/write. This is a safety net, not the
#     primary access control; that lives in this server's own auth checks.)
#   - Project Settings > API: copy the Project URL (SUPABASE_URL) and the
#     service_role secret key (SUPABASE_SERVICE_ROLE_KEY) — NOT the anon key.
#     This key must never be sent to the frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Where the auth server redirects the browser back to after the
# OAuth round-trip. Defaults to http://localhost:5173 (the Vite dev server).
# CLIENT_ORIGIN=http://localhost:5173

# Optional. Port the auth server listens on. Defaults to 8787.
# PORT=8787
